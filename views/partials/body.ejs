<h1>Welcome to CSE Motors!</h1>
<%- messages() %>
<div class="delorean-container">
    <picture>
        <source srcset="images/vehicles/delorean-tn.jpg" media="(max-width: 300px)">
        <img src="images/vehicles/delorean.jpg" alt="Delorean Car">
    </picture>
    <div class="delorean-info">
        <h2>DMC Delorean</h2>
        <p>
            3 Cup holders<br>
            Superman doors<br>
            Fuzzy dicel
        </p>
        <button>Own Today</button>
    </div>
</div>
 
<div class="multiple-grid">
    <div class="reviews-container">
        <h1>DMC Delorean Reviews</h1>
        <ul>
            <li>"So fast it's almost like traveling in time." (4/5)</li>
            <li>"Coolest ride on the road." (4/5)</li>
            <li>"I'm feeling McFly!" (5/5)</li>
            <li>"The most futeristic ride of our day." (4.5/5)</li>
            <li>"80's livin and I love it!." (5/5)</li>
        </ul>
    </div>
 
    <div class="upgrade-container">
        <h1>Delorean Upgrades</h1>
        <div id="upgradesGrid">
            <div>
                <div class="upgrade-img-box">
                    <img src="images/upgrades/flux-cap.png" alt="Flux Capacitor">
                </div>
                <a href="">Flux Capacitor</a>
            </div>
            <div>
                <div class="upgrade-img-box">
                    <img src="images/upgrades/flame.jpg" alt="Flame Decals">
                </div>
                <a href="">Flame Decals</a>
            </div>
            <div>
                <div class="upgrade-img-box">
                    <img src="images/upgrades/bumper_sticker.jpg" alt="Bumper Stickers">
                </div>
                <a href="">Bumper Stickers</a>
            </div>
            <div>
                <div class="upgrade-img-box">
                    <img src="images/upgrades/hub-cap.jpg" alt="Hub Caps">
                </div>
                <a href="">Hub Caps</a>
            </div>
        </div>
    </div>
</div>
<div class="reviews-container">
    <h1>DMC Delorean Reviews</h1>

    <ul>
        <% if (reviews && reviews.length > 0) { %>
            <% reviews.forEach(review => { %>
                <li>
                    "<%= review.review_text %>" 
                    (<%= review.rating %>/5)
                </li>
            <% }) %>
        <% } else { %>
            <li>No reviews yet. Be the first!</li>
        <% } %>
    </ul>

    <h2>Add Your Review</h2>
    <form action="/reviews/add" method="POST">
        
        <label for="review_text">Review:</label><br>
        <textarea name="review_text" id="review_text" required></textarea><br>

        <label for="rating">Rating:</label><br>
        <select name="rating" id="rating" required>
            <option value="">Select Rating</option>
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5">5</option>
        </select><br><br>

        <input type="hidden" name="vehicle_id" value="1">

        <button type="submit">Submit Review</button>
    </form>
</div>